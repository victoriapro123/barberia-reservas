rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          "victoriap.rodriguezs@gmail.com",
          "maitegalleguillos23@gmail.com"
        ];
    }

    function isValidDateLabel(value) {
      return value is string
        && value.matches("^(lunes|martes|miercoles|jueves|viernes) \\d{2}/\\d{2}$");
    }

    function isValidDateISO(value) {
      return value is string
        && value.matches("^\\d{4}-\\d{2}-\\d{2}$");
    }

    function isAllowedHour(hour) {
      return hour in ["10:00", "11:00", "12:00", "13:00", "15:00", "16:00", "17:00", "18:00", "19:00"];
    }

    function areAllowedHours(hours) {
      return hours is list
        && hours.size() > 0
        && hours.size() <= 9
        && hours.hasOnly(["10:00", "11:00", "12:00", "13:00", "15:00", "16:00", "17:00", "18:00", "19:00"]);
    }

    function areAllowedHoursOrEmpty(hours) {
      return hours is list
        && hours.size() <= 9
        && hours.hasOnly(["10:00", "11:00", "12:00", "13:00", "15:00", "16:00", "17:00", "18:00", "19:00"]);
    }

    function isAllowedService(serviceName) {
      return serviceName in ["corte de pelo", "corte de pelo + barba", "barba"];
    }

    function isAllowedPublicSlotState(state) {
      return state in ["pendiente", "confirmada"];
    }

    function isSizedString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isValidEmail(value) {
      return value is string
        && value.size() <= 120
        && value.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$");
    }

    function isValidPhone(value) {
      return value is string
        && value.matches("^[+\\d\\s()\\-]{8,20}$");
    }

    function isOwnerDocument(data) {
      return request.auth != null
        && data.keys().hasAny(["clienteUid"])
        && data.clienteUid == request.auth.uid;
    }

    function hasRequiredBaseKeys(data) {
      return data.keys().hasAll([
          "barbero",
          "fecha",
          "hora",
          "nombre",
          "correo",
          "telefono",
          "servicio",
          "estado",
          "creadoEn"
        ]);
    }

    function hasOnlyCreateKeys(data) {
      return data.keys().hasOnly([
          "barbero",
          "fecha",
          "fechaISO",
          "hora",
          "nombre",
          "correo",
          "clienteUid",
          "telefono",
          "servicio",
          "estado",
          "creadoEn"
        ]);
    }

    function hasRequiredCalendarFieldsForCreate(data) {
      return data.keys().hasAll(["fechaISO"])
        && isValidDateLabel(data.fecha)
        && isValidDateISO(data.fechaISO);
    }

    function hasValidAuthenticatedClientForCreate(data) {
      return request.auth != null
        && request.auth.token.email is string
        && data.keys().hasAll(["clienteUid"])
        && data.clienteUid == request.auth.uid
        && data.correo == request.auth.token.email;
    }

    function hasRequiredPublicSlotKeys(data) {
      return data.keys().hasAll([
          "barbero",
          "fecha",
          "fechaISO",
          "hora",
          "estado",
          "creadoEn"
        ]);
    }

    function hasOnlyPublicSlotKeys(data) {
      return data.keys().hasOnly([
          "barbero",
          "fecha",
          "fechaISO",
          "hora",
          "estado",
          "creadoEn",
          "actualizadoEn"
        ]);
    }

    function isValidPublicSlot(data) {
      return hasRequiredPublicSlotKeys(data)
        && hasOnlyPublicSlotKeys(data)
        && data.barbero == "Barber Elite"
        && isValidDateLabel(data.fecha)
        && isValidDateISO(data.fechaISO)
        && isAllowedHour(data.hora)
        && isAllowedPublicSlotState(data.estado);
    }

    function keepsOptionalDateISOField() {
      return (
        !resource.data.keys().hasAny(["fechaISO"])
        && !request.resource.data.keys().hasAny(["fechaISO"])
      ) || (
        resource.data.keys().hasAny(["fechaISO"])
        && request.resource.data.keys().hasAny(["fechaISO"])
        && request.resource.data.fechaISO == resource.data.fechaISO
      );
    }

    function keepsOptionalClientUidField() {
      return (
        !resource.data.keys().hasAny(["clienteUid"])
        && !request.resource.data.keys().hasAny(["clienteUid"])
      ) || (
        resource.data.keys().hasAny(["clienteUid"])
        && request.resource.data.keys().hasAny(["clienteUid"])
        && request.resource.data.clienteUid == resource.data.clienteUid
      );
    }

    function hasOnlyAllowedUpdatedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "estado",
        "gestionadoEn",
        "gestionadoPor",
        "finalizadoEn",
        "finalizadoPor",
        "notaInterna",
        "notaActualizadaEn",
        "notaActualizadaPor"
      ]);
    }

    function hasValidOptionalNoteFields(data) {
      return (
        !data.keys().hasAny(["notaInterna"])
        || (data.notaInterna is string && data.notaInterna.size() <= 500)
      )
      && (
        !data.keys().hasAny(["notaActualizadaPor"])
        || data.notaActualizadaPor == request.auth.token.email
      )
      && (
        !data.keys().hasAny(["notaActualizadaEn"])
        || data.notaActualizadaEn == request.time
        || (
          resource.data.keys().hasAny(["notaActualizadaEn"])
          && data.notaActualizadaEn == resource.data.notaActualizadaEn
        )
      );
    }

    function hasValidOptionalManagementFields(data) {
      return (
        !data.keys().hasAny(["gestionadoPor"])
        || data.gestionadoPor == request.auth.token.email
        || (
          resource.data.keys().hasAny(["gestionadoPor"])
          && data.gestionadoPor == resource.data.gestionadoPor
        )
      )
      && (
        !data.keys().hasAny(["gestionadoEn"])
        || data.gestionadoEn == request.time
        || (
          resource.data.keys().hasAny(["gestionadoEn"])
          && data.gestionadoEn == resource.data.gestionadoEn
        )
      );
    }

    function hasValidOptionalCompletionFields(data) {
      return (
        !data.keys().hasAny(["finalizadoPor"])
        || data.finalizadoPor == request.auth.token.email
        || data.finalizadoPor == null
      )
      && (
        !data.keys().hasAny(["finalizadoEn"])
        || data.finalizadoEn == request.time
        || data.finalizadoEn == null
      );
    }

    function keepsImmutableFields() {
      return request.resource.data.barbero == resource.data.barbero
        && request.resource.data.fecha == resource.data.fecha
        && keepsOptionalDateISOField()
        && request.resource.data.hora == resource.data.hora
        && request.resource.data.nombre == resource.data.nombre
        && request.resource.data.correo == resource.data.correo
        && keepsOptionalClientUidField()
        && request.resource.data.telefono == resource.data.telefono
        && request.resource.data.servicio == resource.data.servicio
        && request.resource.data.creadoEn == resource.data.creadoEn;
    }

    function hasValidStateTransition() {
      return (
        request.resource.data.estado == resource.data.estado
      ) || (
        resource.data.estado in ["confirmada", "cancelada"]
        && request.resource.data.estado == "pendiente"
      ) || (
        resource.data.estado == "pendiente"
        && request.resource.data.estado == "confirmada"
        && request.resource.data.gestionadoPor == request.auth.token.email
        && request.resource.data.gestionadoEn == request.time
      ) || (
        resource.data.estado in ["pendiente", "confirmada"]
        && request.resource.data.estado == "cancelada"
        && request.resource.data.gestionadoPor == request.auth.token.email
        && request.resource.data.gestionadoEn == request.time
      ) || (
        resource.data.estado in ["pendiente", "confirmada"]
        && request.resource.data.estado == "completada"
        && request.resource.data.finalizadoPor == request.auth.token.email
        && request.resource.data.finalizadoEn == request.time
      );
    }

    function isValidAgendaConfig(data) {
      return data.keys().hasOnly([
          "lunesAbierto",
          "lunesHoras",
          "martesAbierto",
          "martesHoras",
          "miercolesAbierto",
          "miercolesHoras",
          "juevesAbierto",
          "juevesHoras",
          "viernesAbierto",
          "viernesHoras",
          "horasDescanso",
          "limiteReservasPorDia",
          "minutosMinimosAnticipacion",
          "actualizadoEn",
          "actualizadoPor"
        ])
        && data.lunesAbierto is bool
        && data.martesAbierto is bool
        && data.miercolesAbierto is bool
        && data.juevesAbierto is bool
        && data.viernesAbierto is bool
        && areAllowedHours(data.lunesHoras)
        && areAllowedHours(data.martesHoras)
        && areAllowedHours(data.miercolesHoras)
        && areAllowedHours(data.juevesHoras)
        && areAllowedHours(data.viernesHoras)
        && areAllowedHoursOrEmpty(data.horasDescanso)
        && data.limiteReservasPorDia is int
        && data.limiteReservasPorDia >= 1
        && data.limiteReservasPorDia <= 9
        && data.minutosMinimosAnticipacion is int
        && data.minutosMinimosAnticipacion >= 0
        && data.minutosMinimosAnticipacion <= 1440
        && data.actualizadoPor == request.auth.token.email
        && data.actualizadoEn == request.time;
    }

    function isValidBlockedDate(data, docId) {
      return data.keys().hasOnly([
          "fechaISO",
          "motivo",
          "actualizadoEn",
          "actualizadoPor"
        ])
        && isValidDateISO(data.fechaISO)
        && data.fechaISO == docId
        && (
          !data.keys().hasAny(["motivo"])
          || (data.motivo is string && data.motivo.size() <= 120)
        )
        && data.actualizadoPor == request.auth.token.email
        && data.actualizadoEn == request.time;
    }

    function isValidSpecialDate(data, docId) {
      return data.keys().hasOnly([
          "fechaISO",
          "horas",
          "nota",
          "actualizadoEn",
          "actualizadoPor"
        ])
        && isValidDateISO(data.fechaISO)
        && data.fechaISO == docId
        && areAllowedHours(data.horas)
        && (
          !data.keys().hasAny(["nota"])
          || (data.nota is string && data.nota.size() <= 120)
        )
        && data.actualizadoPor == request.auth.token.email
        && data.actualizadoEn == request.time;
    }

    function hasOnlyClientReservationKeys(data) {
      return data.keys().hasOnly([
          "barbero",
          "fecha",
          "fechaISO",
          "hora",
          "nombre",
          "correo",
          "clienteUid",
          "telefono",
          "servicio",
          "estado",
          "creadoEn",
          "actualizadoEn"
        ]);
    }

    function keepsClientReservationImmutableFields() {
      return request.resource.data.barbero == resource.data.barbero
        && request.resource.data.fecha == resource.data.fecha
        && request.resource.data.fechaISO == resource.data.fechaISO
        && request.resource.data.hora == resource.data.hora
        && request.resource.data.nombre == resource.data.nombre
        && request.resource.data.correo == resource.data.correo
        && request.resource.data.clienteUid == resource.data.clienteUid
        && request.resource.data.telefono == resource.data.telefono
        && request.resource.data.servicio == resource.data.servicio
        && request.resource.data.creadoEn == resource.data.creadoEn;
    }

    match /solicitudes_reserva/{requestId} {
      allow create: if
        hasRequiredBaseKeys(request.resource.data)
        && hasOnlyCreateKeys(request.resource.data)
        && hasValidAuthenticatedClientForCreate(request.resource.data)
        && request.resource.data.barbero == "Barber Elite"
        && request.resource.data.estado == "pendiente"
        && hasRequiredCalendarFieldsForCreate(request.resource.data)
        && isAllowedHour(request.resource.data.hora)
        && isSizedString(request.resource.data.nombre, 3, 60)
        && isValidEmail(request.resource.data.correo)
        && isValidPhone(request.resource.data.telefono)
        && isAllowedService(request.resource.data.servicio)
        && request.resource.data.creadoEn == request.time;

      allow read: if isAdmin();

      allow update: if isAdmin()
        && hasRequiredBaseKeys(request.resource.data)
        && hasOnlyAllowedUpdatedKeys()
        && keepsImmutableFields()
        && request.resource.data.estado in ["pendiente", "confirmada", "cancelada", "completada"]
        && hasValidStateTransition()
        && hasValidOptionalManagementFields(request.resource.data)
        && hasValidOptionalCompletionFields(request.resource.data)
        && hasValidOptionalNoteFields(request.resource.data);

      allow delete: if false;
    }

    match /reservas_cliente/{requestId} {
      allow create: if
        hasRequiredBaseKeys(request.resource.data)
        && hasOnlyClientReservationKeys(request.resource.data)
        && request.resource.data.barbero == "Barber Elite"
        && hasRequiredCalendarFieldsForCreate(request.resource.data)
        && isAllowedHour(request.resource.data.hora)
        && isSizedString(request.resource.data.nombre, 3, 60)
        && isValidEmail(request.resource.data.correo)
        && isValidPhone(request.resource.data.telefono)
        && isAllowedService(request.resource.data.servicio)
        && (
          (
            hasValidAuthenticatedClientForCreate(request.resource.data)
            && request.resource.data.estado == "pendiente"
            && request.resource.data.creadoEn == request.time
            && !request.resource.data.keys().hasAny(["actualizadoEn"])
          ) || (
            isAdmin()
            && request.resource.data.estado in ["pendiente", "confirmada", "cancelada", "completada"]
            && request.resource.data.creadoEn is timestamp
            && (
              !request.resource.data.keys().hasAny(["actualizadoEn"])
              || request.resource.data.actualizadoEn == request.time
            )
          )
        );

      allow read: if isAdmin() || isOwnerDocument(resource.data);

      allow update: if isAdmin()
        && hasRequiredBaseKeys(request.resource.data)
        && hasOnlyClientReservationKeys(request.resource.data)
        && keepsClientReservationImmutableFields()
        && request.resource.data.estado in ["pendiente", "confirmada", "cancelada", "completada"]
        && request.resource.data.actualizadoEn == request.time;

      allow delete: if false;
    }

    match /configuracion_publica/agenda {
      allow read: if true;
      allow create, update: if isAdmin() && isValidAgendaConfig(request.resource.data);
      allow delete: if false;
    }

    match /agenda_fechas_bloqueadas/{fechaISO} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBlockedDate(request.resource.data, fechaISO);
      allow delete: if isAdmin();
    }

    match /agenda_fechas_especiales/{fechaISO} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidSpecialDate(request.resource.data, fechaISO);
      allow delete: if isAdmin();
    }

    match /agenda_publica/{slotId} {
      allow read: if true;

      allow create: if
        isValidPublicSlot(request.resource.data)
        && (
          (
            request.auth != null
            && !isAdmin()
            && request.resource.data.estado == "pendiente"
            && request.resource.data.creadoEn == request.time
            && !request.resource.data.keys().hasAny(["actualizadoEn"])
          ) || (
            isAdmin()
            && request.resource.data.creadoEn == request.time
            && (
              !request.resource.data.keys().hasAny(["actualizadoEn"])
              || request.resource.data.actualizadoEn == request.time
            )
          )
        );

      allow update: if isAdmin()
        && isValidPublicSlot(request.resource.data)
        && request.resource.data.barbero == resource.data.barbero
        && request.resource.data.fecha == resource.data.fecha
        && request.resource.data.fechaISO == resource.data.fechaISO
        && request.resource.data.hora == resource.data.hora
        && request.resource.data.creadoEn == resource.data.creadoEn
        && request.resource.data.actualizadoEn == request.time;

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
